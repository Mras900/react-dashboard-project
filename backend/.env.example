# =============================================================
# Backend Dashboard — Variables de entorno
# =============================================================
# IMPORTANTE: No subir backend/.env con credenciales reales.
# En produccion configurar estas variables en Portainer.
#
# El dashboard tiene su propio PostgreSQL (dashboard_postgres).
# NO usar boletas_postgres para esta app.
# NO usar 192.168.1.93 dentro de Docker para esta conexion.
# =============================================================

# Credenciales de la base de datos propia del dashboard
DASHBOARD_DB_NAME=ruta_dashboard
DASHBOARD_DB_USER=ruta_user
DASHBOARD_DB_PASSWORD=CHANGE_ME

# URL de conexion — dentro de Docker el host es dashboard_postgres
DATABASE_URL=postgresql://ruta_user:CHANGE_ME@dashboard_postgres:5432/ruta_dashboard

# Administrador inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_DISPLAY_NAME=Administrador

# JWT — generar con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Duracion de sesion en minutos (opcional, default 480)
ACCESS_TOKEN_MINUTES=480

# OpenWeather API key (opcional — para clima desde backend)
# No subir claves reales. En produccion configurar en Portainer.
OPENWEATHER_API_KEY=CHANGE_ME_OPENWEATHER_API_KEY

# CRM (opcional — solo si se integra con CRM externo)
CRM_BASE_URL=
CRM_USERNAME=
CRM_PASSWORD=
# IA multi-proveedor (opcional — solo backend; no exponer en React)
AI_PROVIDER=nvidia
AI_FALLBACK_PROVIDER=gemini

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# IA/RAG futuro (embeddings aun no implementados)
ENABLE_VECTOR_SEARCH=false
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
