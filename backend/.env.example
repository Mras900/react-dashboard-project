# =============================================================
# Backend - Variables de entorno
# =============================================================
# IMPORTANTE: No subir .env con credenciales reales.
# En produccion configurar estas variables en Portainer.
# =============================================================

# Base de datos PostgreSQL (usar boletas_postgres como host dentro de Docker)
DATABASE_URL=postgresql://dashboard_user:CHANGE_ME@boletas_postgres:5432/dashboard_db

# CRM (opcional si no se usa)
CRM_BASE_URL=
CRM_USERNAME=
CRM_PASSWORD=

# Autenticacion JWT
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Admin inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_DISPLAY_NAME=Administrador

# Sesion
ACCESS_TOKEN_MINUTES=480
