{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [],
  "rules": {
    "react-inline-styles/no-style-attribute": "off",
    "jsx-a11y/aria-role": "off",
    "jsx-a11y/aria-proptypes": "off",
    "no-inline-styles": "off"
  }
}
